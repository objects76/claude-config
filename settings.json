{
  "env": {
    "ENABLE_TOOL_SEARCH": "false",
    "CLAUDE_CODE_DISABLE_CRON": "1",
    "LITE_LLM_SETTING_PLACE_HOLDER": "",
    "DISABLE_AUTOUPDATER": "1",
    "TELEGRAM4LLM": "8359515533:AAF01-dS1Eg6sRdfBfyC8HYsonHNtpFXdvk"
  },
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Blob",
      "List",
      "WebSearch",
      "WebFetch",
      "Stat",
      "Tree",
      "Diff"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/hook_session.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/hook_session.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "/home/jjkim/.claude/hooks/hook_session.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "mgrep@Mixedbread-Grep": false,
    "codex@openai-codex": true,
    "skill-creator@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "watch@claude-video": true,
    "understand-anything@understand-anything": true
  },
  "extraKnownMarketplaces": {
    "Mixedbread-Grep": {
      "source": {
        "source": "github",
        "repo": "mixedbread-ai/mgrep"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "claude-video": {
      "source": {
        "source": "github",
        "repo": "bradautomates/claude-video"
      }
    },
    "understand-anything": {
      "source": {
        "source": "github",
        "repo": "Lum1104/Understand-Anything"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "auto",
  "skipAutoPermissionPrompt": true
}
